<Window x:Class="CopilotBuddy.UI.PluginsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Plugins" 
        Height="450" 
        Width="400"
        WindowStartupLocation="CenterOwner"
        Background="#2D2D30"
        ResizeMode="CanResize">
    
    <Window.Resources>
        <!-- Styles pour thème sombre -->
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#3F3F46"/>
        </Style>
        
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>
        
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#CCCCCC"/>
        </Style>
        
        <Style TargetType="Button">
            <Setter Property="Background" Value="#3F3F46"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="BorderBrush" Value="#555555"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#505050"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#606060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Liste des plugins -->
        <ListBox x:Name="lstPlugins"
                 Grid.Row="0"
                 SelectionMode="Single"
                 SelectionChanged="LstPlugins_SelectionChanged"
                 HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" Margin="5">
                        <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay}"
                                  VerticalAlignment="Center"
                                  Checked="Plugin_CheckedChanged"
                                  Unchecked="Plugin_CheckedChanged"
                                  Margin="0,0,10,0"/>
                        <TextBlock Text="{Binding Name}" 
                                   VerticalAlignment="Center"
                                   Foreground="#CCCCCC"
                                   FontSize="14"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Informations du plugin sélectionné -->
        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Row="0" Grid.Column="0" Content="Author:" FontWeight="Bold" Margin="0,0,10,0"/>
            <Label Grid.Row="0" Grid.Column="1" x:Name="lblAuthor" Content=""/>

            <Label Grid.Row="1" Grid.Column="0" Content="Version:" FontWeight="Bold" Margin="0,0,10,0"/>
            <Label Grid.Row="1" Grid.Column="1" x:Name="lblVersion" Content=""/>
        </Grid>

        <!-- Boutons d'action -->
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Left"
                    Margin="0,10,0,0">
            <Button x:Name="btnSettings"
                    Content="Settings"
                    Width="90"
                    Height="28"
                    Click="BtnSettings_Click"
                    IsEnabled="False"/>
            <Button x:Name="btnRefresh"
                    Content="Refresh"
                    Width="90"
                    Height="28"
                    Margin="10,0,0,0"
                    Click="BtnRefresh_Click"/>
        </StackPanel>

        <!-- Bouton Close -->
        <Button Grid.Row="3"
                Content="Close"
                Width="90"
                Height="28"
                HorizontalAlignment="Right"
                Margin="0,10,0,0"
                Click="BtnClose_Click"/>
    </Grid>
</Window>
