<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:CopilotBuddy.Buddy.Overlay.Controls">

    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

    <Style x:Key="{x:Type controls:OverlayControl}"
           TargetType="{x:Type controls:OverlayControl}">
        <Setter Property="MinHeight" Value="10" />
        <Setter Property="MinWidth" Value="10" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:OverlayControl}">
                    <Border BorderBrush="{TemplateBinding BorderBrush}"
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                        <UIElement.InputBindings>
                            <MouseBinding MouseAction="LeftClick"
                                          Command="{Binding Path=DragMoveCommand, RelativeSource={RelativeSource TemplatedParent}}" />
                        </UIElement.InputBindings>
                        <Grid Margin="1" Background="{TemplateBinding Background}">
                            <ContentPresenter Name="PART_ContentHost"
                                              Content="{TemplateBinding Content}"
                                              Margin="{TemplateBinding Padding}" />
                            <TextBlock Name="PART_Resizer"
                                       Text="p"
                                       FontFamily="Marlett"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Bottom"
                                       Cursor="SizeNWSE"
                                       Visibility="{TemplateBinding AllowResizing, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <UIElement.InputBindings>
                                    <MouseBinding MouseAction="LeftClick"
                                                  Command="{Binding Path=DragResizeCommand, RelativeSource={RelativeSource TemplatedParent}}" />
                                </UIElement.InputBindings>
                            </TextBlock>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
